@{
    ViewData["Title"] = "Home Page";
}


<div class="text-center">
    <h1 class="display-4">LineBot 機器人測試頁面</h1>
    <div class="row mb-4">
        <input type="text" class="form-control" id="message" placeholder="請輸入要推播的訊息">
        <input type="text" class="form-control" id="groupId" placeholder="請輸入 Line 群組的 GroupId 的訊息">
        <div class="col">
            <button class="btn btn-primary" type="button" id="publishLineBot">送出推播訊息</button>
        </div>
    </div>
    <div id="showinfo">...</div>
</div>


@section Scripts {
    <script>
                $(document).ready(function () {

                    $("#publishLineBot").click(function () {
                        CallPublishLineBot();
                    });
                });

                function CallPublishLineBot() {
                    debugger;
                    $.ajax({
                        url: '@Url.Action("LinePublish", "Home")',
                        type: 'GET',
                        data: {
                            "message": document.getElementById('message').value,
                            "groupId": document.getElementById('groupId').value,
                        },
                        success: function (response) {
                            alert(response);
                            document.getElementById('showinfo').innerHTML = response;
                            ;
                        },
                        error: function () {
                        }
                    });
                }

    </script>
}
